{
  "name": "sidekick",
  "version": "1.4.0",
  "description": "Sidekick — a collection of AI coding agents as Claude sidekicks. Starting with Forge (ForgeCode), each sidekick auto-installs, configures itself, and lets Claude delegate coding work while Claude focuses on planning and communication.",
  "author": {
    "name": "Ālo Labs",
    "url": "https://alolabs.dev"
  },
  "homepage": "https://github.com/alo-exp/sidekick",
  "repository": "https://github.com/alo-exp/sidekick",
  "license": "MIT",
  "keywords": [
    "sidekick",
    "forge",
    "forgecode",
    "terminal-agent",
    "coding-agent",
    "openrouter",
    "orchestration"
  ],
  "skills": "./skills/",
  "commands": "./commands/",
  "outputStyles": "./output-styles/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash|mcp__filesystem__write_file|mcp__filesystem__edit_file|mcp__filesystem__move_file|mcp__filesystem__create_directory",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/forge-delegation-enforcer.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-release-gate.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/forge-progress-surface.sh\""
          }
        ]
      }
    ]
  },
  "_integrity": {
    "_note": "SHA-256 hashes of plugin files — update on each release. Verify source at https://github.com/alo-exp/sidekick. (SENTINEL FINDING-R8-4/R10-3)",
