{
  "name": "sidekick",
  "version": "1.5.3",
  "description": "Sidekick — a collection of AI coding agents as Claude sidekicks. Forge and Code are the first two: each sidekick auto-installs, configures itself, and lets Claude delegate coding work while Claude focuses on planning and communication. The workflow bodies live in skills, and the slash-command files are thin wrappers for discoverability.",
  "author": {
    "name": "Ālo Labs",
    "url": "https://alolabs.dev"
  },
  "homepage": "https://github.com/alo-exp/sidekick",
  "repository": "https://github.com/alo-exp/sidekick",
  "license": "MIT",
  "keywords": [
    "sidekick",
    "forge",
    "codex",
    "forgecode",
    "code-exec",
    "terminal-agent",
    "coding-agent",
    "openrouter",
    "orchestration"
  ],
  "skills": "./skills/",
  "commands": "./commands/",
  "outputStyles": "./output-styles/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash|mcp__filesystem__write_file|mcp__filesystem__edit_file|mcp__filesystem__move_file|mcp__filesystem__create_directory",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/forge-delegation-enforcer.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/codex-delegation-enforcer.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-release-gate.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/forge-progress-surface.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/codex-progress-surface.sh\""
          }
        ]
      }
    ]
  },
  "_integrity": {
