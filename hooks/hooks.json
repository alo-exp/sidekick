{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash|mcp__filesystem__write_file|mcp__filesystem__edit_file|mcp__filesystem__move_file|mcp__filesystem__create_directory",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(printf '%s' \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${SIDEKICK_PLUGIN_ROOT:-}}}\" | sed 's#/.Codex/#/.codex/#g; s#/.Codex$#/.codex#')\"; bash \"${ROOT}/hooks/forge-delegation-enforcer.sh\""
          },
          {
            "type": "command",
            "command": "ROOT=\"$(printf '%s' \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${SIDEKICK_PLUGIN_ROOT:-}}}\" | sed 's#/.Codex/#/.codex/#g; s#/.Codex$#/.codex#')\"; bash \"${ROOT}/hooks/codex-delegation-enforcer.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"$(printf '%s' \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${SIDEKICK_PLUGIN_ROOT:-}}}\" | sed 's#/.Codex/#/.codex/#g; s#/.Codex$#/.codex#')\"; bash \"${ROOT}/hooks/forge-progress-surface.sh\""
          },
          {
            "type": "command",
            "command": "ROOT=\"$(printf '%s' \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${SIDEKICK_PLUGIN_ROOT:-}}}\" | sed 's#/.Codex/#/.codex/#g; s#/.Codex$#/.codex#')\"; bash \"${ROOT}/hooks/codex-progress-surface.sh\""
          }
        ]
      }
    ]
  }
}
